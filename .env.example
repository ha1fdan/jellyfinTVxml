# HTTP proxy for all outbound requests (EPG API + HLS stream fetches).
# Credentials can be embedded in the URL or omitted for unauthenticated proxies.
#
# HTTP_PROXY=http://user:pass@proxy.host:3128
# HTTPS_PROXY=http://user:pass@proxy.host:3128

# How long (in seconds) to cache EPG data before re-fetching from DR (default: 3600 = 1 hour).
#
# EPG_CACHE_TTL=3600

# Proxy HLS stream URLs through the local server (default: false).
# Set to true to route streams through the local /proxy endpoint.
# Accepted values: 1, true, yes  (anything else disables it)
#
# PROXY_STREAMS=true

# Proxy image URLs (channel logos, programme thumbnails) through the local server.
# Useful if your Jellyfin can't reach external image hosts directly.
# Accepted values: 1, true, yes  (anything else disables it)
#
# PROXY_IMAGES=true
